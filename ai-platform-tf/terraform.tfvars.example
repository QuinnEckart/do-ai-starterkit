# DigitalOcean AI Platform - Terraform Configuration
# Copy this file to terraform.tfvars and fill in your values

# =============================================================================
# REQUIRED - GitHub Repository
# =============================================================================

# Your GitHub repo containing the ai-starter-kit-app code
# Format: "username/repo-name" (e.g., "johndoe/do-ai-starterkit")
app_source_repo = ""

# =============================================================================
# REQUIRED - DigitalOcean Credentials
# =============================================================================

# Your DigitalOcean API token (https://cloud.digitalocean.com/account/api/tokens)
do_token = "dop_v1_your_api_token_here"

# Spaces access keys (https://cloud.digitalocean.com/spaces -> Manage Keys)
spaces_access_id  = "your_spaces_access_key"
spaces_secret_key = "your_spaces_secret_key"

# =============================================================================
# REQUIRED - GenAI Configuration
# =============================================================================

# DigitalOcean GenAI endpoint or any OpenAI-compatible endpoint
genai_endpoint = "https://your-agent.ondigitalocean.app"
genai_api_key  = "your_genai_api_key"

# =============================================================================
# OPTIONAL - Customize Your Deployment
# =============================================================================

# Stack name (used as prefix for all resources)
# stack_name = "ai-platform"

# Region for deployment
# region = "nyc3"

# Model configuration
# default_model     = "llama-3.1-70b-instruct"
# embedding_model   = "bge-large-en-v1.5"

# RAG tuning
# chunk_size        = 512    # Words per chunk
# chunk_overlap     = 64     # Overlap between chunks
# rag_top_k         = 5      # Number of chunks to retrieve
# cache_ttl_seconds = 3600   # Cache TTL (1 hour)

# Database sizing (adjust based on your workload)
# pg_size_slug     = "db-s-2vcpu-4gb"   # PostgreSQL size
# valkey_size_slug = "db-s-1vcpu-1gb"   # Valkey (cache) size

# App Platform sizing
# app_instance_size = "basic-xxs"

# Alerting
# enable_uptime_alert = true
# alert_email = "your-email@example.com"
