# DigitalOcean AI Platform - Local Development Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# INFERENCE (Required for AI responses)
# =============================================================================
GENAI_ENDPOINT=https://your-agent.ondigitalocean.app
GENAI_API_KEY=your_api_key
DEFAULT_MODEL=llama-3.1-70b-instruct

# =============================================================================
# EMBEDDINGS (Required for RAG/semantic search)
# =============================================================================
# Leave empty to use GENAI_ENDPOINT/GENAI_API_KEY
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# =============================================================================
# POSTGRESQL (Knowledge Base)
# =============================================================================
PG_HOST=your-db-host.db.ondigitalocean.com
PG_PORT=25060
PG_DATABASE=kb
PG_USER=doadmin
PG_PASSWORD=your_password

# =============================================================================
# VALKEY (Cache)
# =============================================================================
VALKEY_HOST=your-valkey-host.db.ondigitalocean.com
VALKEY_PORT=25061
VALKEY_PASSWORD=your_password

# =============================================================================
# SPACES (Document Storage)
# =============================================================================
SPACES_BUCKET=your-bucket-name
SPACES_REGION=nyc3
SPACES_ACCESS_KEY=your_access_key
SPACES_SECRET_KEY=your_secret_key

# =============================================================================
# RAG CONFIGURATION
# =============================================================================
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5
CACHE_TTL_SECONDS=3600
